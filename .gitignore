.env
*.env.local

# --- Database ---
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Jupyter ---
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# --- Testing ---
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# --- Distribution ---
*.tar.gz
*.whl

# --- Logs ---
*.log
logs/
